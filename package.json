{
  "name": "figma-plugin-template",
  "description": "Figma/FigJam plugin boilerplate with React, Vite, TypeScript, and Turborepo monorepo",
  "private": true,
  "license": "MIT",
  "author": "Jonas Bröms",
  "repository": {
    "type": "git",
    "url": "https://github.com/jonasbroms/figma-plugin-template"
  },
  "keywords": [
    "figma",
    "figma-plugin",
    "figjam",
    "react",
    "vite",
    "typescript",
    "turborepo",
    "monorepo",
    "bun",
    "biome",
    "vitest",
    "boilerplate",
    "template"
  ],
  "engines": {
    "node": ">=18",
    "bun": ">=1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "turbo": "^2.9.6"
  },
  "packageManager": "bun@1.3.11",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "analyze": "turbo run analyze",
    "types": "turbo run types"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
